generator client {
  provider   = "prisma-client-js"
  engineType = "none"
}

datasource db {
  provider = "postgresql"
}

model User {
  email              String              @unique
  provider           PaymentProvider?
  providerCustomerId String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  dateOfBirth        DateTime?
  name               String?
  roles              String[]            @default(["user"])
  id                 Int                 @id @default(autoincrement())
  creditTransactions CreditTransaction[]
  creditWallet       CreditWallet?
  payments           Payment[]
  paymentMethods     PaymentMethod[]
  subscription       Subscription?
}

model Plan {
  id               String          @id @default(cuid())
  code             String          @unique
  name             String
  renewalCredits   Int
  resetIntervalDay Int
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  pricingOptions   PricingOption[]
}

model BillingCycle {
  id             String          @id @default(cuid())
  name           String
  durationDay    Int
  pricingOptions PricingOption[]
}

model PricingOption {
  id                    String              @id @default(cuid())
  planId                String
  billingCycleId        String
  name                  String
  price                 Decimal
  currency              String
  provider              PaymentProvider?
  providerPriceId       String?
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  billingCycle          BillingCycle        @relation(fields: [billingCycleId], references: [id])
  plan                  Plan                @relation(fields: [planId], references: [id])
  subscriptions         Subscription[]
  subscriptionEventsNew SubscriptionEvent[] @relation("NewPricing")
  subscriptionEventsOld SubscriptionEvent[] @relation("OldPricing")
}

model Subscription {
  id                           String              @id @default(cuid())
  pricingOptionId              String
  status                       SubscriptionStatus
  currentPeriodStart           DateTime
  currentPeriodEnd             DateTime
  nextCreditResetAt            DateTime
  subscriptionCreditsRemaining Int
  autoRenew                    Boolean             @default(true)
  provider                     PaymentProvider?
  providerSubscriptionId       String?
  cancelledAt                  DateTime?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  userId                       Int                 @unique
  trialEnd                     DateTime?
  trialStart                   DateTime?
  invoices                     Invoice[]
  pricingOption                PricingOption       @relation(fields: [pricingOptionId], references: [id])
  user                         User                @relation(fields: [userId], references: [id])
  events                       SubscriptionEvent[]
}

model CreditWallet {
  addonCredits Int      @default(0)
  updatedAt    DateTime @updatedAt
  userId       Int      @id
  user         User     @relation(fields: [userId], references: [id])
}

model AddonPackage {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  credits         Int
  price           Decimal
  currency        String
  provider        PaymentProvider?
  providerPriceId String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  payments        Payment[]
}

model Invoice {
  id                String          @id @default(cuid())
  subscriptionId    String
  provider          PaymentProvider
  providerInvoiceId String?         @unique
  amount            Decimal
  currency          String
  status            InvoiceStatus
  retryCount        Int             @default(0)
  nextRetryAt       DateTime?
  dueAt             DateTime
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  billingReason     String?
  subscription      Subscription    @relation(fields: [subscriptionId], references: [id])
  payments          Payment[]
}

model Payment {
  id                String          @id @default(cuid())
  invoiceId         String?
  addonPackageId    String?
  provider          PaymentProvider
  providerPaymentId String          @unique
  amount            Decimal
  currency          String
  status            PaymentStatus
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  userId            Int
  addonPackage      AddonPackage?   @relation(fields: [addonPackageId], references: [id])
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id])
  user              User            @relation(fields: [userId], references: [id])
}

model PaymentMethod {
  id                      String          @id @default(cuid())
  provider                PaymentProvider
  providerPaymentMethodId String
  isDefault               Boolean
  metadata                Json?
  createdAt               DateTime        @default(now())
  userId                  Int
  user                    User            @relation(fields: [userId], references: [id])
}

model CreditTransaction {
  id            String                @id @default(cuid())
  type          CreditTransactionType
  amount        Int
  description   String?
  referenceType ReferenceType?
  referenceId   String?
  createdAt     DateTime              @default(now())
  userId        Int
  user          User                  @relation(fields: [userId], references: [id])
}

model SubscriptionEvent {
  id                 String                @id @default(cuid())
  subscriptionId     String
  type               SubscriptionEventType
  oldPricingOptionId String?
  newPricingOptionId String?
  metadata           Json?
  createdAt          DateTime              @default(now())
  newPricingOption   PricingOption?        @relation("NewPricing", fields: [newPricingOptionId], references: [id])
  oldPricingOption   PricingOption?        @relation("OldPricing", fields: [oldPricingOptionId], references: [id])
  subscription       Subscription          @relation(fields: [subscriptionId], references: [id])
}

model WebhookEvent {
  id          String          @id
  provider    PaymentProvider
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime        @default(now())
}

enum PaymentProvider {
  STRIPE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
  PAUSED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum CreditTransactionType {
  RENEWAL
  ADDON_PURCHASE
  USAGE
  ADJUSTMENT
  EXPIRATION
  REFUND
}

enum ReferenceType {
  SUBSCRIPTION
  ADDON_PURCHASE
  PAYMENT
  MANUAL
}

enum SubscriptionEventType {
  CREATED
  RENEWED
  UPGRADED
  DOWNGRADED
  CANCELLED
  EXPIRED
  PAUSED
  RESUMED
  PAYMENT_FAILED
  PAYMENT_RECOVERED
}
