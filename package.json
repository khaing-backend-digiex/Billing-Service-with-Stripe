    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "prettier": "^3.4.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.0",
