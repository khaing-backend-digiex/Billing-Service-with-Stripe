model User {
  id String @id

  email String @unique

  provider PaymentProvider?
  providerCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription Subscription?
  creditWallet CreditWallet?

  paymentMethods PaymentMethod[]
  payments Payment[]
  creditTransactions CreditTransaction[]
}

model Plan {
  id String @id @default(cuid())

  code String @unique
  name String

  renewalCredits Int
  resetIntervalDay Int

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricingOptions PricingOption[]
}

model BillingCycle {
  id String @id @default(cuid())

  name String
  durationDay Int

  pricingOptions PricingOption[]
}

model PricingOption {
  id String @id @default(cuid())

  planId String
  billingCycleId String

  name String

  price Decimal
  currency String

  provider PaymentProvider?
  providerPriceId String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  plan Plan @relation(fields: [planId], references: [id])

  billingCycle BillingCycle
      @relation(fields: [billingCycleId], references: [id])

  subscriptions Subscription[]
  subscriptionEventsOld SubscriptionEvent[] @relation("OldPricing")
  subscriptionEventsNew SubscriptionEvent[] @relation("NewPricing")
}

model Subscription {
  id String @id @default(cuid())

  userId String @unique
  pricingOptionId String

  status SubscriptionStatus

  currentPeriodStart DateTime
  currentPeriodEnd DateTime

  nextCreditResetAt DateTime
  subscriptionCreditsRemaining Int

  autoRenew Boolean @default(true)

  provider PaymentProvider?
  providerSubscriptionId String?

  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  user User
      @relation(fields: [userId], references: [id])

  pricingOption PricingOption
      @relation(fields: [pricingOptionId], references: [id])

  invoices Invoice[]

  events SubscriptionEvent[]
}

model CreditWallet {
  userId String @id

  addonCredits Int @default(0)

  updatedAt DateTime @updatedAt

  user User
      @relation(fields: [userId], references: [id])
}

model AddonPackage {
  id String @id @default(cuid())

  code String @unique

  name String

  credits Int

  price Decimal
  currency String

  provider PaymentProvider?
  providerPriceId String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
}

model Invoice {
  id String @id @default(cuid())

  subscriptionId String

  provider PaymentProvider

  providerInvoiceId String?

  amount Decimal

  currency String

  status InvoiceStatus

  retryCount Int @default(0)

  nextRetryAt DateTime?

  dueAt DateTime

  paidAt DateTime?

  createdAt DateTime @default(now())

  subscription Subscription
      @relation(fields: [subscriptionId], references: [id])

  payments Payment[]
}

model Payment {
  id String @id @default(cuid())

  userId String

  invoiceId String?

  addonPackageId String?

  provider PaymentProvider

  providerPaymentId String @unique

  amount Decimal

  currency String

  status PaymentStatus

  paidAt DateTime?

  createdAt DateTime @default(now())

  user User
      @relation(fields: [userId], references: [id])

  invoice Invoice?
      @relation(fields: [invoiceId], references: [id])

  addonPackage AddonPackage?
      @relation(fields: [addonPackageId], references: [id])
}

model PaymentMethod {
  id String @id @default(cuid())

  userId String

  provider PaymentProvider

  providerPaymentMethodId String

  isDefault Boolean

  metadata Json?

  createdAt DateTime @default(now())

  user User
      @relation(fields: [userId], references: [id])
}

model CreditTransaction {
  id String @id @default(cuid())

  userId String

  type CreditTransactionType

  amount Int

  description String?

  referenceType ReferenceType?

  referenceId String?

  createdAt DateTime @default(now())

  user User
      @relation(fields: [userId], references: [id])
}

model SubscriptionEvent {
  id String @id @default(cuid())

  subscriptionId String

  type SubscriptionEventType

  oldPricingOptionId String?
  newPricingOptionId String?

  metadata Json?

  createdAt DateTime @default(now())

  subscription Subscription
      @relation(fields: [subscriptionId], references: [id])

  oldPricingOption PricingOption?
      @relation("OldPricing", fields: [oldPricingOptionId], references: [id])

  newPricingOption PricingOption?
      @relation("NewPricing", fields: [newPricingOptionId], references: [id])
}

model WebhookEvent {
  id String @id

  provider PaymentProvider

  eventId String @unique

  eventType String

  payload Json

  processedAt DateTime?

  createdAt DateTime @default(now())
}